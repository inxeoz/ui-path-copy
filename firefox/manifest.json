{
  "manifest_version": 2,
  "name": "UI Path Copy",
  "version": "1.0.0",
  "description": "Right-click any element to copy its data-testid navigation path for Playwright E2E tests",
  "permissions": [
    "contextMenus",
    "clipboardWrite",
    "activeTab",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "ui-path-copy@ui",
      "strict_min_version": "91.0"
    }
  }
}
