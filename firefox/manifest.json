{
  "manifest_version": 2,
  "name": "CMTS Navigator",
  "version": "1.0.0",
  "description": "Copy data-testid navigation paths from CMTS pages for E2E tests",
  "permissions": [
    "contextMenus",
    "clipboardWrite",
    "activeTab",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "cmts-navigator@cmts",
      "strict_min_version": "91.0"
    }
  }
}
