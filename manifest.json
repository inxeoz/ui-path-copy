{
  "manifest_version": 3,
  "name": "UI Path Copy",
  "version": "1.0.0",
  "description": "Right-click any element to copy its data-testid navigation path for Playwright E2E tests",
  "permissions": [
    "contextMenus",
    "clipboardWrite",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
